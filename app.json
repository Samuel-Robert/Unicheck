{
    "expo": {
      "name": "UniCheck",
      "slug": "unicheck",
      "scheme": "unicheck",
      "version": "1.0.0",
      "orientation": "portrait",
      "icon": "./assets/icons/icon.png",
      "userInterfaceStyle": "light",
      "newArchEnabled": false,
      "splash": {
        "image": "./assets/icons/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0D2A5C"
      },
      "ios": {
        "supportsTablet": false,
        "bundleIdentifier": "com.unicheck.app"
      },
      "android": {
        "adaptiveIcon": {
          "foregroundImage": "./assets/icons/adaptive-icon.png",
          "backgroundColor": "#0D2A5C"
        },
        "package": "com.unicheck.app"
      },
      "web": {
        "favicon": "./assets/images/favicon.png"
      },
      "plugins": [
        "expo-router",
        [
          "expo-camera",
          {
            "cameraPermission": "O UniCheck precisa da câmera para escanear o QRCode de presença."
          }
        ],
        "expo-sqlite"
      ]
    }
  }
